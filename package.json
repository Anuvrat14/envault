{
  "name": "dotward",
  "version": "2.5.6",
  "description": "Encrypted environment variable manager for developers",
  "author": "Anuvrat14",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "FLASK_ENV=development electron .",
    "build:mac-arm64": "electron-builder --mac --arm64",
    "build:mac-x64": "electron-builder --mac --x64",
    "build:win": "electron-builder --win",
    "release": "electron-builder --mac --publish always"
  },
  "build": {
    "appId": "com.dotward.app",
    "productName": "Dotward",
    "copyright": "Copyright © 2026",
    "publish": {
      "provider": "github",
      "owner": "Anuvrat14",
      "repo": "dotward",
      "private": false
    },
    "files": [
      "main.js",
      "preload.js",
      "static/**/*",
      "templates/**/*",
      "package.json"
    ],
    "extraResources": [],
    "mac": {
      "category": "public.app-category.developer-tools",
      "extraResources": [
        {
          "from": "dist/dotward-server",
          "to": "dotward-server"
        },
        {
          "from": "dotward_cli.py",
          "to": "dotward_cli.py"
        }
      ],
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "static/icon.icns"
    },
    "win": {
      "extraResources": [
        {
          "from": "dist/dotward-server.exe",
          "to": "dotward-server.exe"
        },
        {
          "from": "dotward_cli.py",
          "to": "dotward_cli.py"
        },
        {
          "from": "mcp_server.py",
          "to": "mcp_server.py"
        }
      ],
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "static/icon.ico"
    },
    "dmg": {
      "title": "Dotward"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh"
    }
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3"
  }
}
