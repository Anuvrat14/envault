{
  "name": "envault",
  "version": "1.2.0",
  "description": "Encrypted environment variable manager for developers",
  "author": "Anuvrat14",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "FLASK_ENV=development electron .",
    "build:mac-arm64": "electron-builder --mac --arm64",
    "build:mac-x64": "electron-builder --mac --x64",
    "build:win": "electron-builder --win",
    "release": "electron-builder --mac --publish always"
  },
  "build": {
    "appId": "com.envault.app",
    "productName": "Envault",
    "copyright": "Copyright © 2026",
    "publish": {
      "provider": "github",
      "owner": "Anuvrat14",
      "repo": "envault",
      "private": false
    },
    "files": [
      "main.js",
      "static/**/*",
      "templates/**/*",
      "package.json"
    ],
    "extraResources": [],
    "mac": {
      "category": "public.app-category.developer-tools",
      "extraResources": [
        { "from": "dist/envault-server", "to": "envault-server" }
      ],
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        },
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ],
      "icon": "static/icon.icns"
    },
    "win": {
      "extraResources": [
        { "from": "dist/envault-server.exe", "to": "envault-server.exe" }
      ],
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "static/icon.ico"
    },
    "dmg": {
      "title": "Envault"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3"
  }
}
