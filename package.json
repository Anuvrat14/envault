{
  "name": "envault",
  "version": "1.0.0",
  "description": "Encrypted environment variable manager for developers",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "FLASK_ENV=development electron .",
    "build:mac-arm64": "electron-builder --mac --arm64",
    "build:mac-x64": "electron-builder --mac --x64",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.envault.app",
    "productName": "Envault",
    "copyright": "Copyright © 2026",
    "files": [
      "main.js",
      "static/**/*",
      "templates/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/envault-server",
        "to": "envault-server"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "icon": "static/icon.icns"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "static/icon.ico"
    },
    "dmg": {
      "title": "Envault",
      "background": "static/dmg-bg.png"
    },
    "nsis": {
      "oneClick": false,
      "allowDirChange": true,
      "createDesktopShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}
